// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  nama_lengkap        String
  username            String?   @unique @db.VarChar(30)
  password_hash       String?   // Null jika login murni via Google
  provider            String    @default("google") // 'local' atau 'google'
  google_id           String?   @unique
  saldo_aktif         Decimal   @default(0.00) @db.Decimal(15, 2)
  saldo_tertahan      Decimal   @default(0.00) @db.Decimal(15, 2)
  role                UserRole  @default(BASIC)
  kategori            String?   @db.VarChar(50)
  bio                 String?   @db.Text
  instagram           String?   @db.VarChar(100)
  youtube             String?   @db.VarChar(200)
  twitter             String?   @db.VarChar(100)

  // Field Tambahan untuk Fitur Lupa Password (UI Step 3)
  reset_token         String?   @unique @db.VarChar(255)
  reset_token_expires DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  donations           Donation[]
  overlay             OverlaySetting?
  withdrawals         Withdrawal[]

  @@map("users")
}

model Withdrawal {
  id                String           @id @default(uuid())
  streamerId        String
  amount            Decimal          @db.Decimal(15, 2)
  bank_name         String           @db.VarChar(100)
  account_name      String           @db.VarChar(150)
  account_number    String           @db.VarChar(50)
  notes             String?          @db.Text
  status            WithdrawalStatus @default(PENDING)
  processed_at      DateTime?
  cancelled_at      DateTime?
  failure_reason    String?          @db.Text
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  streamer          User             @relation(fields: [streamerId], references: [id], onDelete: Cascade)

  @@index([streamerId, status])
  @@map("withdrawals")
}

model LoginAttempt {
  id             String   @id @default(uuid())
  identifier     String   @db.VarChar(255)
  client_ip      String   @db.VarChar(64)
  failed_attempts Int     @default(0)
  locked_until   DateTime?
  last_attempt_at DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([identifier, client_ip])
  @@index([locked_until])
  @@map("login_attempts")
}

model Donation {
  id                  String    @id @default(uuid())
  streamerId          String
  nama_donatur        String    @default("Anonim") @db.VarChar(100)
  email_donatur       String?   @db.VarChar(200)
  pesan               String?   @db.Text
  jumlah              Decimal   @db.Decimal(15, 2)
  status              String    @default("PENDING") @db.VarChar(20)
  payment_gateway_ref String?   @unique
  payment_method      String?   @db.VarChar(50)
  paid_at             DateTime?

  // AI Moderation fields
  ai_status           String?   @db.VarChar(20)   // SAFE, BLOCKED
  ai_reason           String?   @db.Text           // Alasan jika diblokir AI

  createdAt           DateTime  @default(now())

  streamer            User      @relation(fields: [streamerId], references: [id], onDelete: Cascade)

  @@index([streamerId])
  @@index([status])
  @@map("donations")
}

model OverlaySetting {
  id                  String   @id @default(uuid())
  streamerId          String   @unique
  min_donasi_alert    Decimal  @default(10000.00) @db.Decimal(15, 2)
  durasi_alert        Int      @default(8)
  template_text       String   @default("{name} baru saja memberikan {amount}")
  font_family         String   @default("Inter") @db.VarChar(50)
  nama_color          String   @default("#FFFFFF") @db.VarChar(9)
  template_color      String   @default("#2BBBA0") @db.VarChar(9)
  amount_color        String   @default("#3BA2FF") @db.VarChar(9)
  message_color       String   @default("#FF914D") @db.VarChar(9)
  sound_enabled       Boolean  @default(true)
  sound_min_donasi    Decimal  @default(200000.00) @db.Decimal(15, 2)
  tts_enabled         Boolean  @default(false)
  ai_filter_enabled   Boolean  @default(false)
  banned_words        String?  @db.Text

  streamer            User     @relation(fields: [streamerId], references: [id], onDelete: Cascade)

  @@map("overlay_settings")
}

// Role untuk user
enum UserRole {
  ADMIN
  BASIC
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}
