# Database Configuration
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=komunitip
DB_PORT_EXTERNAL=5433

# NestJS Configuration
PORT=3000

# Google OAuth Configuration
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Mail Configuration (Resend SMTP)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USER=resend
MAIL_PASS=your_resend_api_key_here
MAIL_FROM=noreply@yourdomain.com

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://corazon-unimbibed-pseudoemotionally.ngrok-free.dev

# Public API / socket URL for frontend when not using same-origin proxy
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_PROXY_TARGET=http://backend-api:3000
VITE_SOCKET_URL=http://localhost:3000

# AI Moderation (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Payment Gateway (Xendit)
XENDIT_SECRET_KEY=your_xendit_secret_key_here
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token_here
